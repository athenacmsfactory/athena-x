# Athena CMS - Environment Template (.env)
# Kopieer dit bestand naar .env en vul de juiste waarden in.

### --- Systeem Configuratie ---
ROOT_DIR=/pad/naar/jouw/athena-cms
ATHENA_ROOT=/pad/naar/jouw/athena-cms


### --- AI Model Configuratie & Survival Waterfall ---
# Athena beschikt over een "Survival Engine". Je kunt per taak een specifieke 
# model-stack (komma-gescheiden) opgeven. De engine probeert deze één voor één.
# Als de gehele stack faalt, valt de engine automatisch terug op de volledige 
# centrale waterfall uit factory/config/ai-models.json.

# API Keys
GEMINI_API_KEY=jouw_google_gemini_api_key
OPENROUTER_API_KEY=jouw_openrouter_api_key
GROQ_API_KEY=jouw_groq_api_key
HF_TOKEN=jouw_huggingface_access_token # Fine-grained token met 'Inference' permissies

# Model Stacks per taak
# Tip: Zet je snelste/favoriete model eerst, gevolgd door een betrouwbare gratis backup.

# Model voor het ontwerpen van de datastructuur
AI_MODEL_DATA_ARCHITECT="gemini-2.5-flash,google/gemini-2.0-flash-exp:free,z-ai/glm-4.5-air:free"

# Model voor het schrijven van de parser-instructies
AI_MODEL_SITETYPE_PROMPT_ENGINEER="gemini-2.5-flash,google/gemini-2.0-flash-exp:free"

# Model voor de uiteindelijke content-extractie naar JSON
AI_MODEL_PARSER="deepseek-r1-distill-llama-70b,gemini-2.5-flash,tngtech/deepseek-r1t2-chimera:free"

# Model voor het genereren van DALL-E/Midjourney prompts
AI_MODEL_IMAGE_GENERATOR="gemini-2.5-flash,google/gemini-2.0-flash-exp:free"

# Algemeen fallback-model
AI_MODEL_DEFAULT="gemini-2.5-flash,google/gemini-2.0-flash-exp:free"

# Specifiek model voor MPA (Multi-Page Application) parsing
MPA_PARSER_AI_MODEL=gemini-2.5-flash


### --- GitHub Integratie ---
GITHUB_USER=jouw_github_gebruikersnaam
GITHUB_PAT=ghp_jouw_personal_access_token
GH_TOKEN=ghp_jouw_personal_access_token

# (Optioneel) GitHub organisatie naam (default: GITHUB_USER)
GITHUB_ORG=jouw-organisatie-naam

# (Optioneel) SSH Host alias (default: github.com)
GITHUB_SSH_HOST=github.com

### --- Server Poorten (Systeem Config) ---
DASHBOARD_PORT=3001
DOCK_PORT=3000
LAYOUT_EDITOR_PORT=3030
MEDIA_MAPPER_PORT=3031
PREVIEW_PORT=4000


### --- Google Sheets & Drive (Auto-Provisioning) ---
GOOGLE_SHEETS_API_KEY=jouw_google_sheets_api_key
MASTER_TEMPLATE_ID=id_van_je_master_template_sheet
DRIVE_PROJECTS_FOLDER_ID=id_van_je_drive_map


### --- Google Cloud Platform (GCP) ---
# Benodigd voor schrijf-toegang tot Sheets en Drive via de factory scripts.
GOOGLE_SERVICE_ACCOUNT_EMAIL=athena-backend@project-id.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=jouw_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=jouw_client_secret
GOOGLE_REFRESH_TOKEN=jouw_refresh_token